# ========== 行尾符配置 ==========
# C++ 源代码 (Linux LF)
*.cpp text eol=lf
*.h text eol=lf
*.hpp text eol=lf
*.cc text eol=lf
*.cxx text eol=lf

# C# 代码 (Linux LF)
*.cs text eol=lf

# 配置文件 (Linux LF)
*.ini text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.uproject text eol=lf
*.uplugin text eol=lf

# 文档 (Linux LF)
*.md text eol=lf
*.txt text eol=lf
*.csv text eol=lf
*.sh text eol=lf

# Windows 批处理脚本 (CRLF)
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf